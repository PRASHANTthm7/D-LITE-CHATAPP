# ============================================
# D-Lite AI Backend — Environment Variables
# Copy this to .env and fill in values
# ============================================

ENV=development
PORT=5070

# Supabase — https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Deepgram (Speech-to-Text) — https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_key_here

# Deepgram (Text-to-Speech & Speech-to-Text) — https://console.deepgram.com
# Optional: set a preferred TTS voice and TTS/STT model names here
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_TTS_VOICE=alloy
DEEPGRAM_TTS_MODEL=gpt-tts
DEEPGRAM_STT_MODEL=nova-2

# CORS — comma separated allowed origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app
